{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": ["*.ts", "broker/**/*.ts", "opencode/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
