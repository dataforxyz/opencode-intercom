{
  "name": "opencode-intercom",
  "version": "0.1.0",
  "description": "OpenCode plugin for direct local messaging with Pi, Codex, Claude, and OpenCode coding-agent sessions.",
  "license": "MIT",
  "type": "module",
  "main": "dist/plugin.mjs",
  "exports": {
    ".": "./dist/plugin.mjs"
  },
  "files": [
    "dist/**/*",
    "opencode/**/*.ts",
    "broker/**/*.ts",
    "scripts/**/*",
    "types.ts",
    "config.ts",
    "README.md",
    "PLAN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "test": "tsx --test broker/client.test.ts broker/framing.test.ts broker/paths.test.ts broker/spawn.test.ts"
  },
  "keywords": [
    "opencode",
    "intercom",
    "multi-agent",
    "pi",
    "codex",
    "claude"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.15"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  }
}
